# DBTower 셀프호스트 설정 — cp .env.example .env 후 값을 채우세요.
# 이 파일(.env)은 절대 커밋하지 마세요(.gitignore 에 포함).

# [필수] 메타 DB(플랫폼 저장소) 비밀번호. 앱과 meta-db 컨테이너가 공유한다.
DBTOWER_DB_PASSWORD=change-me-strong-password

# [권장] 관리자 초기 비밀번호. 비우면 앱이 첫 부팅에 랜덤 생성 후 로그로 1회 안내한다.
DBTOWER_ADMIN_PASSWORD=

# [권장] 등록 대상 DB의 접속 비밀번호를 저장 시 암호화하는 키(AES-256-GCM).
#        생성:  openssl rand -base64 32
#        비우면 대상 비밀번호가 평문으로 저장되고 부팅 시 WARN 이 뜬다.
DBTOWER_ENCRYPTION_KEY=

# [선택] 이상 감지 알림 웹훅 URL(Discord/Slack 호환). 비우면 알림 비활성.
DBTOWER_WEBHOOK_URL=

# [선택] 노출 포트 / 이미지 태그 / JVM 옵션
DBTOWER_PORT=8080
DBTOWER_TAG=latest
JAVA_OPTS=-XX:MaxRAMPercentage=75
